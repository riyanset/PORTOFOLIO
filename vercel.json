{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0",
      "memory": 1024
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/thumb.php", "dest": "/api/thumb.php" },
    { "src": "/(.*\\.php)$", "dest": "/api/index.php" },
    { "src": "/", "dest": "/api/index.php" }
  ]
}
